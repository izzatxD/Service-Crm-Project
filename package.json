{
  "name": "crm-web-project-workspace",
  "private": true,
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ./scripts/dev.ps1",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-dev.ps1",
    "dev:status": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-status.ps1",
    "lint:backend": "npm --prefix backend run lint",
    "build:backend": "npm --prefix backend run build",
    "test:backend": "npm --prefix backend run test -- --runInBand",
    "test:e2e:backend": "npm --prefix backend run test:e2e",
    "verify:backend": "npm run lint:backend && npm run build:backend && npm run test:backend && npm run test:e2e:backend",
    "lint:frontend": "npm --prefix frontend run lint",
    "build:frontend": "npm --prefix frontend run build",
    "verify:frontend": "npm run lint:frontend && npm run build:frontend",
    "verify": "npm run verify:backend && npm run verify:frontend"
  }
}
